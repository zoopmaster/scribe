# series.config — per-series knobs read by the scribe engine (walk-up from any chapter).
# Lives in the series folder. Overrides speaker.config for this series only. Simple
# `key: value` lines; `#` comments and blank lines ignored.

# H1 / book title. Leave empty for a standalone (non-series) sermon (H1 = its own title).
series_title:

# true → chapters are numbered "Part N — …" installments.
numbered: true

# Proper-noun seed for transcription: the speaker base PLUS this series' key proper nouns
# (book names, characters, places) so Whisper spells them right.
whisper_prompt:

# Anything else (speaker, scripture_note, book_label, bible_*) is inherited from speaker.config
# unless a series genuinely needs to differ — then set it here.
