# speaker.config — speaker-wide knobs read by the scribe engine (walk-up from any chapter).
# Lives in the speaker's project root, ABOVE the series folders. A series.config overrides
# any of these per series. Simple `key: value` lines; `#` comments and blank lines ignored.

# Byline name as it should appear in the book.
speaker:

# Front-matter scripture note (Markdown). Lint checks each chapter contains this line.
scripture_note: *Scripture quotations are from the <VERSION> unless marked otherwise.*

# Label shown in the rendered book header.
book_label: Book edition

# Default Bible version label + verification lookup base + the alternate version to switch
# to when the speaker's exposition leans on its specific wording. Read by the agent (the
# scripture step), not the rendering scripts.
bible_version:
bible_url_base:
alt_version:

# Proper-noun seed base for transcription. Each series.config APPENDS its own key nouns by
# setting a fuller whisper_prompt; this is the speaker-wide floor.
whisper_prompt: Sermon by <SPEAKER>. <tradition / church / recurring proper nouns>.
